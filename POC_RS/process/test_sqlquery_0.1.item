    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT OMM.ModuleDocumentID,ClassAssociationID,CA.ObjectClassID,ModShortName,FromTo,OC.ObjectClassName,OC.SourceModule,&#xD;&#xA;CA.ParentClassAssociationID,CA.KeyColumn,IsMultiple,IsReUsable,IsSystem,NeedHierarchy,DocumentName,&#xD;&#xA;OmnexWebinar.dbo.[UDF_BOGetParentObjectClassName](CA.ParentClassAssociationID) as ParentObjectClassName,&#xD;&#xA;OmnexWebinar.dbo.[UDF_BOGETClassNodePath](cast(ClassAssociationID as varchar(100))) COLLATE DATABASE_DEFAULT +'/'+ &#xD;&#xA;cast(OC.ObjectClassName as VARCHAR(500)) COLLATE DATABASE_DEFAULT as ClassPath,&#xD;&#xA;IIF(FromTo is NULL,'BO_'+ModShortName+'_'+OC.ObjectClassName,'BO_'+ModShortName+'_'+FromTo+'_'+OC.ObjectClassName) DwTableName&#xD;&#xA;FROM OmnexWebinar.dbo.BOObjectModelMapping OMM&#xD;&#xA;Inner JOIN OmnexWebinar.dbo.BOModuleDocument MD ON MD.ModuleDocumentID = OMM.ModuleDocumentID&#xD;&#xA;Inner JOIN OmnexWebinar.dbo.SUModules SM on SM.modid = MD.ModuleID&#xD;&#xA;Inner JOIN OmnexWebinar.dbo.BOClassAssociation CA ON CA.ObjectModelMappingID = OMM.ObjectModelMappingID&#xD;&#xA;Inner JOIN OmnexWebinar.dbo.BOObjectClass OC on CA.ObjectClassID = OC.ObjectClassID WHERE OMM.ObjectModelMappingID=4&#xD;&#xA;ORDER BY ParentClassAssociationID,ClassAssociationID&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
    <elementParameter field="MAPPING_TYPE" name="MAPPING" value="id_MSSQL" show="false"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;encrypt=true;trustServerCertificate=true;&quot;"/>
    <elementParameter field="CHECK" name="ACTIVE_DIR_AUTH" value="false"/>
    <elementParameter field="CLOSED_LIST" name="ACTIVE_DIR_AUTH_MODE" value="PASSWORD" show="false"/>
